---
interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  url: string;
  coverImage?: string;
}

const { title, description, pubDate, url, coverImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<a class="blog-card" href={url} target="_blank" rel="noopener noreferrer">
  <div class="blog-card-cover">
    {
      coverImage ? (
        <img src={coverImage} alt={title} loading="lazy" />
      ) : (
        <div class="blog-card-cover-ph" />
      )
    }
  </div>
  <div class="blog-card-body">
    <h3 class="blog-card-title">{title}</h3>
    {description && <p class="blog-card-desc">{description}</p>}
    <div class="blog-card-foot">
      <span class="blog-card-byline">{formattedDate}</span>
      <span class="blog-card-arr">→</span>
    </div>
  </div>
</a>
