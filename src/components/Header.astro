---
import MobileMenu from "./MobileMenu.tsx";

const links = [
  { href: "/", label: "Home" },
  { href: "/faq", label: "FAQ" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="relative bg-forest text-white">
  <div
    class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4"
  >
    <a
      href="/"
      class="text-xl font-bold tracking-tight text-white hover:text-mint-teal"
    >
      Fabric Planning
    </a>

    <nav class="hidden md:block">
      <ul class="flex items-center gap-8">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium text-white hover:text-mint-teal"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <MobileMenu client:load />
  </div>
</header>
