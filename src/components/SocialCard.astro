---
interface Props {
  author: string;
  platform: "linkedin" | "reddit" | "twitter";
  url: string;
  date: Date;
  excerpt: string;
  image?: string;
  likes?: number;
  comments?: number;
}

const { author, platform, url, date, excerpt, image, likes = 0 } = Astro.props;

const platformLabel =
  platform === "linkedin"
    ? "LinkedIn"
    : platform === "reddit"
      ? "Reddit"
      : "Twitter";

const formattedDate = date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
});

const reactionCount = likes > 0 ? `${likes} reactions` : null;
---

<article class="social-card">
  <div class="card-header">
    <span class="platform-label">{platformLabel}</span>
    <span class="card-date">{formattedDate}</span>
  </div>

  <div class="card-author">{author}</div>

  <blockquote class="card-quote">{excerpt}</blockquote>

  {
    image && (
      <img
        src={image}
        alt={`Post by ${author}`}
        loading="lazy"
        class="card-image"
      />
    )
  }

  <div class="card-footer">
    {reactionCount && <span>{reactionCount}</span>}
    <a href={url} target="_blank" rel="noopener noreferrer" class="card-link">
      Read →
    </a>
  </div>
</article>

<style>
  .social-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 240px;
    min-width: 300px;
    max-width: 340px;
    scroll-snap-align: start;
    transition: border-color 0.15s, transform 0.15s;
  }

  .social-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    font-weight: 600;
  }

  .platform-label {
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .platform-label::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .card-date {
    color: var(--fg-muted);
  }

  .card-author {
    font-size: 16px;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .card-quote {
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-soft);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--fg-muted);
    padding-top: 14px;
    border-top: 1px solid var(--rule);
    font-weight: 500;
  }

  .card-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .card-link:hover {
    opacity: 0.8;
  }
</style>
