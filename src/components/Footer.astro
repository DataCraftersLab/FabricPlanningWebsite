---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="brand">
          <span class="brand-mark" aria-hidden="true">F</span>
          <span>
            <span class="brand-name">Fabric Planning</span><span class="brand-sub">.io</span>
          </span>
        </a>
        <p class="footer-brand-about">
          An independent knowledge hub for Microsoft Fabric Planning. Not affiliated with Microsoft.
          Sponsored by <a href="https://datacrafters.io" target="_blank" rel="noopener noreferrer">Data Crafters</a>,
          a Microsoft Fabric Featured Partner.
        </p>
      </div>

      <!-- Resources -->
      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/resources/events">Events</a></li>
          <li><a href="/resources/blog">Blog</a></li>
          <li><a href="/resources/social-media">Community</a></li>
          <li><a href="/faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Subscribe -->
      <div class="footer-col">
        <h4>Subscribe</h4>
        <ul>
          <li>
            <a href="https://fabricplanning.substack.com" target="_blank" rel="noopener noreferrer">
              Substack
            </a>
          </li>
          <li>
            <a href="https://www.meetup.com/finance-fabric-user-group/" target="_blank" rel="noopener noreferrer">
              Meetup
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/khaledchowdhury/" target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          </li>
        </ul>
      </div>

      <!-- About -->
      <div class="footer-col">
        <h4>About</h4>
        <ul>
          <li><a href="/about">About the hub</a></li>
          <li><a href="/about">Contributors</a></li>
          <li>
            <a href="https://datacrafters.io" target="_blank" rel="noopener noreferrer">
              Data Crafters
            </a>
          </li>
          <li><a href="mailto:hello@fabricplanning.io">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} Fabric Planning · Published by Data Crafters</span>
      <span></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-0);
    color: var(--fg-soft);
    padding: 80px 0 36px;
    border-top: 1px solid var(--rule);
    position: relative;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--rule);
  }

  /* Brand column */
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--fg);
  }
  .brand-mark {
    width: 34px;
    height: 34px;
    background: linear-gradient(135deg, var(--cyan) 0%, var(--cyan-700) 100%);
    color: var(--cyan-ink);
    display: grid;
    place-items: center;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    border-radius: 6px;
    box-shadow: 0 0 0 1px rgba(0, 240, 209, 0.25);
    flex-shrink: 0;
  }
  .brand-name {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--fg);
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .footer-brand-about {
    margin-top: 20px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 32ch;
  }
  .footer-brand-about a {
    color: var(--cyan);
    text-decoration: none;
    font-weight: 500;
  }
  .footer-brand-about a:hover { text-decoration: underline; }

  /* Link columns */
  .footer-col h4 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg);
    font-weight: 500;
    margin: 0 0 18px;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a {
    font-size: 14px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--cyan); }

  /* Bottom bar */
  .footer-bottom {
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  @media (max-width: 1100px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
