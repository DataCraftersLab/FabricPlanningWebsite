---
import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { fetchSubstackPosts } from "../../utils/substackFeed";
import blogStickyConfig from "../../content/config/blog-sticky.json";

const allPosts = await fetchSubstackPosts();
const stickyUrl = blogStickyConfig.stickyPostUrl;
const stickyPost = stickyUrl ? allPosts.find((p) => p.url === stickyUrl) : undefined;
const otherPosts = allPosts
  .filter((p) => p.url !== stickyUrl)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
---

<Layout
  title="Blog — Fabric Planning"
  description="Articles, insights, and community content about Microsoft Fabric Planning."
>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <span class="eyebrow"><span class="section-no">§</span> Resources</span>
      <h1><span class="italic">Blog</span></h1>
      <p class="page-hero-sub">
        Articles, insights, and community content about Microsoft Fabric Planning.
      </p>
    </div>
  </section>

  <section class="slab" style="padding-top: 88px;">
    <div class="container">

      <!-- Substack -->
      <div class="block">
        <h2 class="page-h2">
          <span class="substack-tag">■</span> Fabric Planning on Substack
        </h2>
        {
          allPosts.length === 0 ? (
            <div class="soft-panel">
              <h3>Blog coming soon</h3>
              <p>Subscribe on Substack to be notified when we publish our first articles.</p>
              <a class="btn btn-primary" href="https://fabricplanning.substack.com" target="_blank" rel="noopener noreferrer">
                Subscribe on Substack
              </a>
            </div>
          ) : (
            <div class="blog-posts">
              {stickyPost && (
                <div class="sticky-post">
                  <BlogCard
                    title={stickyPost.title}
                    description={stickyPost.description}
                    pubDate={stickyPost.pubDate}
                    url={stickyPost.url}
                    coverImage={stickyPost.coverImage}
                  />
                </div>
              )}
              {otherPosts.length > 0 && (
                <div class="card-grid">
                  {otherPosts.map((post) => (
                    <BlogCard
                      title={post.title}
                      description={post.description}
                      pubDate={post.pubDate}
                      url={post.url}
                      coverImage={post.coverImage}
                    />
                  ))}
                </div>
              )}
            </div>
          )
        }
      </div>

      <!-- Community blogs -->
      <div class="block">
        <h2 class="page-h2">Other Community Blogs</h2>
        <div class="soft-panel">
          <h3>Coming soon</h3>
          <p>
            We&rsquo;re building a curated collection of the best Fabric Planning
            content from across the community. Check back soon.
          </p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .sticky-post {
    margin-bottom: 24px;
  }
  /* Override blog-card to be wider for sticky */
  .sticky-post :global(.blog-card) {
    max-width: 560px;
  }
</style>
