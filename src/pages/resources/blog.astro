---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Blog — Fabric Planning"
  description="The Fabric Planning blog is coming soon. Subscribe to the newsletter to be notified when we publish."
>
  <section class="bg-purple-wash">
    <div
      class="mx-auto flex min-h-[60vh] max-w-[1200px] flex-col items-center justify-center px-6 py-24 text-center"
    >
      <p
        class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-fabric-purple"
      >
        Blog
      </p>
      <h1
        class="mb-6 text-4xl font-bold tracking-tight text-forest md:text-5xl"
      >
        Coming soon
      </h1>
      <p class="mb-10 max-w-xl text-base leading-relaxed text-slate-text md:text-lg">
        The Fabric Planning blog is coming soon. Subscribe to our newsletter to
        be notified when we publish our first articles.
      </p>
      <a
        href="#"
        class="inline-flex items-center justify-center rounded-lg px-8 py-4 text-base font-semibold text-white shadow-md transition hover:shadow-lg"
        style="background: linear-gradient(135deg, #7B61B8 0%, #5B3F9E 100%);"
      >
        Subscribe on Substack
      </a>
    </div>
  </section>
</Layout>
