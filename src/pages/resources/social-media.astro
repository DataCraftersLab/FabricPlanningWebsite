---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SocialCard from "../../components/SocialCard.astro";

const posts = (await getCollection("socialMedia")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout
  title="From the Community — Fabric Planning"
  description="Discussions, insights, and updates on Microsoft Fabric Planning from across social media."
>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <span class="eyebrow"><span class="section-no">§</span> Resources</span>
      <h1>From the <span class="italic">Community</span></h1>
      <p class="page-hero-sub">
        Discussions, insights, and updates on Microsoft Fabric Planning from
        across LinkedIn, Reddit, and beyond.
      </p>
    </div>
  </section>

  <section class="slab" style="padding-top: 88px;">
    <div class="container">
      {
        posts.length === 0 ? (
          <div class="soft-panel">
            <h3>No community posts yet</h3>
            <p>Check back soon — we curate posts from across the community regularly.</p>
          </div>
        ) : (
          <div class="card-grid">
            {posts.map((post) => (
              <SocialCard
                author={post.data.author}
                platform={post.data.platform}
                url={post.data.url}
                date={post.data.date}
                excerpt={post.data.excerpt}
                image={post.data.image}
                likes={post.data.likes}
                comments={post.data.comments}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>
