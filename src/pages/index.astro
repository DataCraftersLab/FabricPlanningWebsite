---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SocialCard from "../components/SocialCard.astro";
import { getEventStatus } from "../utils/eventStatus";
import { fetchSubstackPosts } from "../utils/substackFeed";
import blogStickyConfig from "../content/config/blog-sticky.json";

const allEvents = await getCollection("events");
const upcomingEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "upcoming")
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "past")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const socialPosts = (await getCollection("socialMedia")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allPosts = await fetchSubstackPosts();
const stickyUrl = blogStickyConfig.stickyPostUrl;
const stickyPost = stickyUrl ? allPosts.find((p) => p.url === stickyUrl) : undefined;
const featuredPost = stickyPost ?? (allPosts.length > 0 ? allPosts[0] : undefined);
const listedPosts = allPosts
  .filter((p) => !featuredPost || p.url !== featuredPost.url)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
  .slice(0, 4);

const nextEvent = upcomingEvents[0];
const daysUntil = nextEvent
  ? Math.max(0, Math.ceil((nextEvent.data.date.getTime() - Date.now()) / (1000 * 60 * 60 * 24)))
  : null;
const daysLabel =
  daysUntil === null
    ? null
    : daysUntil === 0
      ? "Today"
      : daysUntil === 1
        ? "Tomorrow"
        : `In ${daysUntil} days`;

function fmtDay(d: Date) {
  return d.getDate().toString().padStart(2, "0");
}
function fmtMon(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short" });
}
function fmtEventDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    weekday: "short",
  });
}
function fmtPostDate(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
function getTypeLabel(type: "virtual" | "in-person" | "webinar") {
  return type === "virtual"
    ? "Virtual"
    : type === "in-person"
      ? "In-person"
      : "Webinar";
}
function getTypeDotColor(type: "virtual" | "in-person" | "webinar") {
  return type === "virtual"
    ? "var(--accent)"
    : type === "in-person"
      ? "var(--dc-badge-blue)"
      : "var(--dc-badge-red)";
}
---

<Layout
  title="Fabric Planning — The Microsoft Fabric Knowledge Hub"
  description="Everything you need to understand, evaluate, and implement Microsoft Fabric Planning. Built by practitioners, for practitioners."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero-inner">
      <!-- Left: headline + CTAs -->
      <div class="hero-main">
        <span class="eyebrow">Microsoft Fabric knowledge hub</span>
        <h1>
          Planning, now <span class="mark">native</span><br />to the fabric of
          your data.
        </h1>
        <p class="hero-sub">
          A working archive for finance and data teams adopting Microsoft Fabric
          Planning — built by practitioners, updated weekly. No vendor spin, no
          50-page decks. Just what works, what doesn't, and what to do next.
        </p>
        <div class="hero-actions">
          <a
            class="btn btn-primary"
            href="https://fabricplanning.substack.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Read the latest issue <span class="arr">→</span>
          </a>
          <a
            class="btn btn-ghost"
            href="https://fabricplanning.substack.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Subscribe on Substack
          </a>
          {allPosts.length > 0 && <span class="pill">Updated recently</span>}
        </div>
      </div>

      <!-- Right: next event card -->
      {
        nextEvent ? (
          <aside class="hero-side">
            <div class="hero-side-label">
              <span>Next event</span>
              {daysLabel && <span class="live-badge">{daysLabel}</span>}
            </div>
            <div class="hero-side-title">{nextEvent.data.title}</div>
            <div class="hero-side-meta">
              <div>
                <div class="meta-k">Date</div>
                <div class="meta-v">{fmtEventDate(nextEvent.data.date)}</div>
              </div>
              <div>
                <div class="meta-k">Time</div>
                <div class="meta-v">{nextEvent.data.time}</div>
              </div>
              <div>
                <div class="meta-k">Format</div>
                <div class="meta-v">
                  {getTypeLabel(nextEvent.data.type)}
                </div>
              </div>
              {nextEvent.data.location && (
                <div>
                  <div class="meta-k">Location</div>
                  <div class="meta-v">{nextEvent.data.location}</div>
                </div>
              )}
            </div>
            <a
              class="hero-side-cta"
              href={nextEvent.data.registrationUrl ?? "#"}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Register free</span>
              <span>→</span>
            </a>
          </aside>
        ) : (
          <aside class="hero-side hero-side-empty">
            <div class="hero-side-label">
              <span>Events</span>
            </div>
            <div class="hero-side-title">
              No upcoming events scheduled right now.
            </div>
            <p class="hero-side-sub">
              Check back soon — new sessions are added regularly.
            </p>
            <a
              class="hero-side-cta"
              href="/resources/events"
            >
              <span>Browse recordings</span>
              <span>→</span>
            </a>
          </aside>
        )
      }

      <!-- Stats strip -->
      <div class="hero-stats" style="grid-column: 1 / -1;">
        <div class="stat-cell">
          <div class="stat-k">Articles published</div>
          <div class="stat-v">
            {allPosts.length > 0 ? allPosts.length : "—"}<span class="stat-u"
              >.</span
            >
          </div>
        </div>
        <div class="stat-cell">
          <div class="stat-k">Events &amp; recordings</div>
          <div class="stat-v">
            {allEvents.length > 0 ? allEvents.length : "—"}<span class="stat-u"
              >.</span
            >
          </div>
        </div>
        <div class="stat-cell">
          <div class="stat-k">User group members</div>
          <div class="stat-v">412<span class="stat-u">.</span></div>
        </div>
        <div class="stat-cell">
          <div class="stat-k">Not affiliated with</div>
          <div class="stat-v">Microsoft<span class="stat-u">.</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EXPLAINER ============ -->
  <section class="slab">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">§ 01 · Primer</span>
          <h2>
            What, exactly, is <span class="mark">Fabric Planning</span>?
          </h2>
          <p class="section-sub">
            The short version, for finance leaders deciding whether to pay
            attention.
          </p>
        </div>
        <a class="section-link" href="/faq">Start here →</a>
      </div>

      <div class="explainer">
        <div class="explainer-lede">
          A new capability inside Microsoft Fabric that brings budgeting,
          forecasting, and financial planning <span class="mark">alongside</span
          > the Power BI reports and data pipelines you already run.
        </div>
        <div class="explainer-body">
          <p>
            For the first time, finance teams can build planning models in the
            same environment their data engineers build in. That single fact has
            large implications — for EPM vendors, for the Excel-heavy status
            quo, and for how finance organises itself against the rest of the
            business.
          </p>
          <p>
            Fabric Planning is still early. The product changes monthly.
            Capabilities that shipped at Ignite look meaningfully different by
            April. This hub exists to help practitioners navigate the moving
            target — what it can do today, where the gaps are, and how to get
            started without betting the roadmap.
          </p>
          <div class="pull-stats">
            <div>
              <div class="pull-k">Launched</div>
              <div class="pull-v">Ignite 2025</div>
            </div>
            <div>
              <div class="pull-k">Built on</div>
              <div class="pull-v">Microsoft Fabric</div>
            </div>
            <div>
              <div class="pull-k">Replaces</div>
              <div class="pull-v">Some of Excel</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EVENTS ============ -->
  <section class="slab slab-elevated">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">§ 02 · Calendar</span>
          <h2>Events &amp; <span class="mark">recordings</span>.</h2>
          <p class="section-sub">
            Upcoming sessions, past recordings, and community meetups.
          </p>
        </div>
        <a class="section-link" href="/resources/events">All events →</a>
      </div>

      <div class="events-grid">
        <!-- Upcoming -->
        <div class="events-col">
          <h3 class="events-col-heading events-col-upcoming">
            <span class="events-col-dot"></span> Upcoming
          </h3>
          {
            upcomingEvents.length === 0 ? (
              <p class="events-empty">
                No upcoming events scheduled. Check back soon.
              </p>
            ) : (
              upcomingEvents.map((event) => (
                <div class="event-row" data-type={event.data.type}>
                  <div class="event-date">
                    <span class="event-day">{fmtDay(event.data.date)}</span>
                    <span class="event-mon">{fmtMon(event.data.date)}</span>
                  </div>
                  <div class="event-meta">
                    <div class="event-type">
                      <span
                        class="event-type-dot"
                        style={`background: ${getTypeDotColor(event.data.type)}`}
                      />
                      {getTypeLabel(event.data.type)}
                      {event.data.time ? ` · ${event.data.time}` : ""}
                    </div>
                    <div class="event-title">{event.data.title}</div>
                    {event.data.location && (
                      <div class="event-loc">{event.data.location}</div>
                    )}
                  </div>
                  <a
                    class="event-cta"
                    href={event.data.registrationUrl ?? "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Register →
                  </a>
                </div>
              ))
            )
          }
        </div>

        <!-- Recordings -->
        <div class="events-col events-col-past">
          <h3 class="events-col-heading">
            <span class="events-col-dot events-col-dot-muted"></span> Recordings
          </h3>
          {
            pastEvents.length === 0 ? (
              <p class="events-empty">No recordings yet.</p>
            ) : (
              pastEvents.map((event) => (
                <div class="event-row event-row-past" data-type={event.data.type}>
                  <div class="event-date event-date-past">
                    <span class="event-day">{fmtDay(event.data.date)}</span>
                    <span class="event-mon">{fmtMon(event.data.date)}</span>
                  </div>
                  <div class="event-meta">
                    <div class="event-type">
                      <span
                        class="event-type-dot"
                        style="background: var(--fg-faint)"
                      />
                      {getTypeLabel(event.data.type)}
                      {event.data.time ? ` · ${event.data.time}` : ""}
                    </div>
                    <div class="event-title">{event.data.title}</div>
                    {event.data.location && (
                      <div class="event-loc">{event.data.location}</div>
                    )}
                  </div>
                  <a
                    class="event-cta"
                    href={event.data.registrationUrl ?? "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Watch →
                  </a>
                </div>
              ))
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BLOG ============ -->
  <section class="slab">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">§ 03 · From the publication</span>
          <h2>Recent <span class="mark">writing</span>.</h2>
          <p class="section-sub">
            Articles from the Fabric Planning Substack.
          </p>
        </div>
        <a
          class="section-link"
          href="https://fabricplanning.substack.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Archive →
        </a>
      </div>

      {
        allPosts.length === 0 ? (
          <p class="events-empty">
            No articles yet. <a href="https://fabricplanning.substack.com" target="_blank" rel="noopener noreferrer" style="color: var(--accent);">Subscribe to be first to know.</a>
          </p>
        ) : (
          <div class="blog-grid">
            <!-- Featured post -->
            {featuredPost && (
              <a
                class="featured-post"
                href={featuredPost.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="featured-cover">
                  {featuredPost.coverImage ? (
                    <img
                      src={featuredPost.coverImage}
                      alt={featuredPost.title}
                      loading="lazy"
                      class="featured-cover-img"
                    />
                  ) : (
                    <>
                      <span class="featured-tag">Featured</span>
                      <span class="featured-placeholder">
                        [ cover · fabric.pattern ]
                      </span>
                    </>
                  )}
                </div>
                <div class="featured-body">
                  <div class="featured-kicker">
                    {fmtPostDate(featuredPost.pubDate)}
                  </div>
                  <h3 class="featured-title">{featuredPost.title}</h3>
                  {featuredPost.description && (
                    <p class="featured-desc">{featuredPost.description}</p>
                  )}
                  <div class="featured-byline">
                    <span>By Khaled Chowdhury</span>
                    <span class="byline-dot">·</span>
                    <span>The Fabric Whisperer</span>
                  </div>
                </div>
              </a>
            )}

            <!-- Post list -->
            <div class="post-list">
              {listedPosts.map((post, i) => (
                <a class="post-item" href={post.url} target="_blank" rel="noopener noreferrer">
                  <div class="post-num">0{i + 1}</div>
                  <div class="post-content">
                    <h4 class="post-title">{post.title}</h4>
                    <div class="post-meta">
                      <span>{fmtPostDate(post.pubDate)}</span>
                    </div>
                  </div>
                  <span class="post-arr">→</span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ COMMUNITY ============ -->
  <section class="slab slab-elevated">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">§ 04 · Field reports</span>
          <h2>What people <span class="mark">are saying</span>.</h2>
          <p class="section-sub">
            Discussions, insights, and updates from across social media.
          </p>
        </div>
        <a class="section-link" href="/resources/social-media">All posts →</a>
      </div>

      {
        socialPosts.length === 0 ? (
          <p class="events-empty">No community posts yet. Check back soon.</p>
        ) : (
          <div class="community-rail">
            {socialPosts.map((post) => (
              <SocialCard
                author={post.data.author}
                platform={post.data.platform}
                url={post.data.url}
                date={post.data.date}
                excerpt={post.data.excerpt}
                image={post.data.image}
                likes={post.data.likes}
                comments={post.data.comments}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ USER GROUP ============ -->
  <section class="slab">
    <div class="container">
      <div class="ug-layout">
        <div class="ug-body">
          <span class="eyebrow">§ 05 · Community</span>
          <h2 class="ug-heading">
            Join the <span class="mark">Finance Fabric</span> User Group.
          </h2>
          <p class="ug-desc">
            A free monthly user group for finance professionals exploring
            Microsoft Fabric Planning. Hosted by Khaled Chowdhury and Alex
            McPherson. Each session covers one real-world topic — modeling
            patterns, migration stories, writeback, security — followed by open
            Q&amp;A.
          </p>
          <div class="ug-actions">
            <a
              class="btn btn-primary"
              href="https://www.meetup.com/finance-fabric-user-group/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Join on Meetup <span class="arr">→</span>
            </a>
            <span class="pill">Free · monthly · virtual</span>
          </div>
        </div>

        <div class="ug-art">
          <div class="ug-art-tag">FFUG · Est. 2026</div>
          <div class="ug-art-headline">
            Where finance meets <span class="mark">fabric</span>.
          </div>
          <div class="ug-art-stats">
            <div>
              <div class="ug-stat-k">Members</div>
              <div class="ug-stat-v">412</div>
            </div>
            <div>
              <div class="ug-stat-k">Sessions</div>
              <div class="ug-stat-v">
                {allEvents.filter((e) => e.data.isPast).length || 7}
              </div>
            </div>
            <div>
              <div class="ug-stat-k">Cost</div>
              <div class="ug-stat-v">$0</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ NEWSLETTER ============ -->
  <section class="newsletter">
    <div class="container newsletter-inner">
      <div>
        <span class="eyebrow">§ 06 · Subscribe</span>
        <h2 class="newsletter-heading">
          Delivered <span class="mark">weekly</span>. No spam, ever.
        </h2>
        <p class="newsletter-lead">
          One email every Monday with what moved in Fabric Planning last week.
          Archived on Substack. One-click unsubscribe, always.
        </p>
      </div>
      <form
        class="newsletter-form"
        name="newsletter"
        method="POST"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <div class="newsletter-form-row">
          <input
            type="email"
            name="email"
            placeholder="you@company.com"
            required
            class="newsletter-input"
          />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </div>
        <small class="newsletter-note">
          Published by Khaled Chowdhury · archived on Substack · one-click
          unsubscribe.
        </small>
      </form>
    </div>
  </section>
</Layout>

<style>
  /* ============ LAYOUT ============ */
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ============ SHARED ATOMS ============ */
  .eyebrow {
    font-size: 11.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .eyebrow::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-weak);
    flex-shrink: 0;
  }

  .mark {
    color: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 20px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.005em;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(94, 234, 212, 0.35);
  }
  .btn-ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--rule-strong);
  }
  .btn-ghost:hover {
    background: var(--bg-2);
    border-color: var(--accent);
    color: var(--accent);
  }
  .btn .arr {
    transition: transform 0.15s;
  }
  .btn:hover .arr {
    transform: translateX(3px);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--fg-muted);
  }
  .pill::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal-400);
    box-shadow: 0 0 8px var(--teal-400);
    animation: pulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  /* ============ HERO ============ */
  .hero {
    border-bottom: 1px solid var(--rule);
    overflow: hidden;
  }
  .hero-inner {
    padding: 96px 0 88px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: end;
  }
  .hero-main h1 {
    font-weight: 700;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--fg);
    margin: 20px 0 0;
    max-width: 16ch;
  }
  .hero-sub {
    margin-top: 28px;
    max-width: 58ch;
    font-size: 18px;
    line-height: 1.6;
    color: var(--fg-soft);
  }
  .hero-actions {
    margin-top: 36px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  /* Hero side card */
  .hero-side {
    background: var(--bg-1);
    border: 1px solid var(--rule);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }
  .hero-side::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }
  .hero-side-label {
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .live-badge {
    color: var(--teal-400);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .live-badge::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal-400);
    box-shadow: 0 0 8px var(--teal-400);
    animation: pulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .hero-side-title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.018em;
    color: var(--fg);
    line-height: 1.2;
  }
  .hero-side-sub {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
  }
  .hero-side-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
  }
  .meta-k {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 4px;
  }
  .meta-v {
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
  }
  .hero-side-cta {
    display: inline-flex;
    align-items: center;
