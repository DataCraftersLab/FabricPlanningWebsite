---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SocialCard from "../components/SocialCard.astro";

import { getEventStatus } from "../utils/eventStatus";
import { fetchSubstackPosts } from "../utils/substackFeed";
import blogStickyConfig from "../content/config/blog-sticky.json";

const allEvents = await getCollection("events");
const allCourses = (await getCollection("courses")).filter((c) => c.data.available);
const upcomingEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "upcoming")
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "past")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const socialPosts = (await getCollection("socialMedia")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

function parseAspectRatio(s?: string): number {
  if (!s) return 4 / 3;
  const parts = s.split("/");
  return parts.length === 2 ? Number(parts[0]) / Number(parts[1]) : Number(s) || 4 / 3;
}

const allPosts = await fetchSubstackPosts();
const stickyUrl = blogStickyConfig.stickyPostUrl;
const stickyPost = stickyUrl ? allPosts.find((p) => p.url === stickyUrl) : undefined;
const featuredPost = stickyPost ?? (allPosts.length > 0 ? allPosts[0] : undefined);
const listedPosts = allPosts
  .filter((p) => !featuredPost || p.url !== featuredPost.url)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
  .slice(0, 4);

const nextEvent = upcomingEvents[0];
const daysUntil = nextEvent
  ? Math.max(0, Math.ceil((nextEvent.data.date.getTime() - Date.now()) / (1000 * 60 * 60 * 24)))
  : null;
const daysLabel =
  daysUntil === null
    ? null
    : daysUntil === 0
      ? "Today"
      : daysUntil === 1
        ? "Tomorrow"
        : `In ${daysUntil} days`;

function fmtDay(d: Date) {
  return d.getDate().toString().padStart(2, "0");
}
function fmtMon(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short" });
}
function fmtEventDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    weekday: "short",
  });
}
function fmtPostDate(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
function getTypeLabel(type: "virtual" | "in-person" | "webinar") {
  return type === "virtual" ? "Virtual" : type === "in-person" ? "In-person" : "Webinar";
}
---

<Layout
  title="Fabric Planning — The Microsoft Fabric Knowledge Hub"
  description="Everything you need to understand, evaluate, and implement Microsoft Fabric Planning. Built by practitioners, for practitioners."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero-inner">
      <!-- Left: headline + CTAs -->
      <div class="hero-main">
        <span class="eyebrow"><span class="section-no">00</span> Microsoft Fabric knowledge hub</span>
        <h1>
          Planning, now <span class="italic">native</span><br />to the fabric of
          your data.
        </h1>
        <p class="hero-sub">
          Everything you need to understand, evaluate, and implement Microsoft
          Fabric Planning. Built by practitioners, for practitioners.
        </p>
        <div class="hero-actions">
          <a
            class="btn btn-primary"
            href="https://fabricplanning.substack.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Subscribe on Substack <span class="arr">→</span>
          </a>
        </div>
      </div>

      <!-- Right: next event card -->
      {
        nextEvent ? (
          <aside class="hero-side">
            <div class="hero-side-label">
              <span>Next event</span>
              {daysLabel && <span class="live-badge">{daysLabel}</span>}
            </div>
            {nextEvent.data.featuredImage && (
              <div class="hero-side-thumb">
                <img
                  src={nextEvent.data.featuredImage}
                  alt={nextEvent.data.title}
                  loading="lazy"
                />
              </div>
            )}
            <div class="hero-side-title">{nextEvent.data.title}</div>
            <div class="hero-side-meta">
              <div>
                <div class="meta-k">Date</div>
                <div class="meta-v">{fmtEventDate(nextEvent.data.date)}</div>
              </div>
              <div>
                <div class="meta-k">Time</div>
                <div class="meta-v">{nextEvent.data.time}</div>
              </div>
              <div>
                <div class="meta-k">Format</div>
                <div class="meta-v">{getTypeLabel(nextEvent.data.type)}</div>
              </div>
              {nextEvent.data.location && (
                <div>
                  <div class="meta-k">Location</div>
                  <div class="meta-v">{nextEvent.data.location}</div>
                </div>
              )}
            </div>
            <a
              class="hero-side-cta"
              href={nextEvent.data.registrationUrl ?? "#"}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Register free</span>
              <span>→</span>
            </a>
          </aside>
        ) : (
          <aside class="hero-side hero-side-empty">
            <div class="hero-side-label">
              <span>Events</span>
            </div>
            <div class="hero-side-title">
              No upcoming events scheduled right now.
            </div>
            <p class="hero-side-sub">
              Check back soon — new sessions are added regularly.
            </p>
            <a class="hero-side-cta" href="/resources/events">
              <span>Browse recordings</span>
              <span>→</span>
            </a>
          </aside>
        )
      }

    </div>
  </section>

  <!-- ============ EXPLAINER ============ -->
  <section class="slab">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow"><span class="section-no">01</span> Primer</span>
          <h2>
            What, exactly, is <span class="italic">Fabric Planning?</span>
          </h2>
          <p class="section-sub">
            The short version, for finance leaders deciding whether to pay
            attention.
          </p>
        </div>
        <a class="section-link" href="/start-here">Start here →</a>
      </div>

      <div class="explainer">
        <div class="explainer-lede">
          A new capability inside Microsoft Fabric that brings budgeting,
          forecasting, and financial planning <span class="italic">alongside</span
          > the Power BI reports and data pipelines you already run.
        </div>
        <div class="explainer-body">
          <p>
            This represents a potential shift away from standalone EPM tools and
            Excel-based planning toward an integrated, cloud-native approach.
            Fabric Planning is still evolving, and this knowledge hub exists to
            help finance and data professionals navigate what it can do today,
            where the gaps are, and how to get started.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EVENTS ============ -->
  <section class="slab slab-elev">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow"><span class="section-no">02</span> Calendar</span>
          <h2>Events &amp; <span class="italic">recordings.</span></h2>
          <p class="section-sub">
            Upcoming sessions, past recordings, and community meetups.
          </p>
        </div>
        <a class="section-link" href="/resources/events">All events →</a>
      </div>

      <div class="events-split">
        <!-- Upcoming -->
        <div class="events-panel">
          <h3 class="events-group-head">
            <span class="events-col-dot"></span> Upcoming
            {upcomingEvents.length > 0 && (
              <span class="count">{upcomingEvents.length} scheduled</span>
            )}
          </h3>
          {
            upcomingEvents.length === 0 ? (
              <p class="events-empty">No upcoming events scheduled. Check back soon.</p>
            ) : (
              <div class="events-rail">
                {upcomingEvents.map((event) => (
                  <a
                    class="event-card"
                    href={event.data.registrationUrl ?? "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <div class="event-thumb">
                      {event.data.featuredImage && (
                        <img
                          src={event.data.featuredImage}
                          alt={event.data.title}
                          loading="lazy"
                        />
                      )}
                    </div>
                    <div class="event-body">
                      <div class="event-meta-row">
                        <span>{getTypeLabel(event.data.type)}</span>
                        {event.data.location && (
                          <>
                            <span class="event-meta-sep">·</span>
                            <span>{event.data.location}</span>
                          </>
                        )}
                      </div>
                      <h4 class="event-title">{event.data.title}</h4>
                      <p class="event-loc">{event.data.description}</p>
                      <div class="event-card-foot">
                        <span class="event-card-time">{fmtDay(event.data.date)} {fmtMon(event.data.date)} · {event.data.time}</span>
                        <span class="event-card-arr">Register <span>→</span></span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )
          }
        </div>

        <!-- Recordings -->
        <div class="events-panel events-past">
          <h3 class="events-group-head">
            <span class="events-col-dot events-col-dot-muted"></span> Recordings
            {pastEvents.length > 0 && (
              <span class="count">{pastEvents.length} available</span>
            )}
          </h3>
          {
            pastEvents.length === 0 ? (
              <p class="events-empty">No recordings yet.</p>
            ) : (
              <div class="events-rail">
                {pastEvents.map((event) => (
                  <a
                    class="event-card"
                    href={event.data.registrationUrl ?? "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <div class="event-thumb">
                      {event.data.featuredImage && (
                        <img
                          src={event.data.featuredImage}
                          alt={event.data.title}
                          loading="lazy"
                        />
                      )}
                      <span class="event-badge event-badge-past">Recording</span>
                    </div>
                    <div class="event-body">
                      <div class="event-meta-row">
                        <span>{getTypeLabel(event.data.type)}</span>
                        {event.data.location && (
                          <>
                            <span class="event-meta-sep">·</span>
                            <span>{event.data.location}</span>
                          </>
                        )}
                      </div>
                      <h4 class="event-title">{event.data.title}</h4>
                      <p class="event-loc">{event.data.description}</p>
                      <div class="event-card-foot">
                        <span class="event-card-time">{fmtDay(event.data.date)} {fmtMon(event.data.date)}</span>
                        <span class="event-card-arr">Watch <span>→</span></span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )
          }
        </div>

        <!-- Course -->
        {allCourses.length > 0 && (
          <div class="course-group">
            <h3 class="events-group-head">
              <span class="events-col-dot"></span> Course
              <span class="count">{allCourses.length} available</span>
            </h3>
            <div class="course-grid">
              {allCourses.map((course) => (
                <a
                  class="event-card event-card-course"
                  href={course.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  style={`--thumb-ratio: ${parseAspectRatio(course.data.thumbnailAspect)}`}
                >
                  <div class="event-thumb">
                    {course.data.featuredImage && (
                      <img src={course.data.featuredImage} alt={course.data.title} loading="lazy" />
                    )}
                    {course.data.lessons !== undefined && (
                      <span class="event-lessons-chip">
                        <span class="lessons-num">{String(course.data.lessons).padStart(2, "0")}</span>
                        <span class="lessons-label">Lessons</span>
                      </span>
                    )}
                  </div>
                  <div class="event-body">
                    <div class="event-meta-row">
                      <span>{course.data.format}</span>
                      <span class="event-meta-sep">·</span>
                      <span>{course.data.level}</span>
                    </div>
                    <h4 class="event-title">{course.data.title}</h4>
                    <p class="event-loc">{course.data.description}</p>
                    <div class="event-card-foot">
                      <span class="event-card-time">{course.data.duration}</span>
                      <span class="event-card-enroll">Enroll <span>→</span></span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- ============ BLOG ============ -->
  <section class="slab">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow"><span class="section-no">03</span> The Blog</span>
          <h2>From the Blog</h2>
          <p class="section-sub">
            Articles from the Fabric Planning Substack.
          </p>
        </div>
        <a
          class="section-link"
          href="https://fabricplanning.substack.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Archive →
        </a>
      </div>

      {
        allPosts.length === 0 ? (
          <p class="events-empty">
            No articles yet.{" "}
            <a
              href="https://fabricplanning.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              style="color: var(--cyan);"
            >
              Subscribe to be first to know.
            </a>
          </p>
        ) : (
          <div class="blog-grid">
            {featuredPost && (
              <a
                class="featured-post"
                href={featuredPost.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="featured-cover">
                  {featuredPost.coverImage ? (
                    <img
                      src={featuredPost.coverImage}
                      alt={featuredPost.title}
                      loading="lazy"
                      class="featured-cover-img"
                    />
                  ) : (
                    <>
                      <span class="featured-tag">Featured</span>
                      <div class="featured-cover-placeholder">
                        <span>[ cover · fabric.pattern ]</span>
                      </div>
                    </>
                  )}
                </div>
                <div class="featured-body">
                  <div class="featured-kicker">{fmtPostDate(featuredPost.pubDate)}</div>
                  <h3 class="featured-title">{featuredPost.title}</h3>
                  {featuredPost.description && (
                    <p class="featured-desc">{featuredPost.description}</p>
                  )}
                  <div class="featured-byline">
                    <span>By Khaled Chowdhury</span>
                    <span class="byline-dot">·</span>
                    <span>The Fabric Whisperer</span>
                  </div>
                </div>
              </a>
            )}

            <div class="post-list">
              {listedPosts.map((post, i) => (
                <a
                  class="post-item"
                  href={post.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="post-num">0{i + 1}</div>
                  <div class="post-content">
                    <h4 class="post-title">{post.title}</h4>
                    <div class="post-meta">
                      <span>{fmtPostDate(post.pubDate)}</span>
                    </div>
                  </div>
                  <span class="post-arr">→</span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ COMMUNITY ============ -->
  <section class="slab slab-elev">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow"><span class="section-no">04</span> Field reports</span>
          <h2>What people <span class="italic">are saying.</span></h2>
          <p class="section-sub">
            Discussions, insights, and updates from across social media.
          </p>
        </div>
        <a class="section-link" href="/resources/social-media">All posts →</a>
      </div>

      {
        socialPosts.length === 0 ? (
          <p class="events-empty">No community posts yet. Check back soon.</p>
        ) : (
          <div class="community-rail">
            {socialPosts.map((post) => (
              <SocialCard
                author={post.data.author}
                platform={post.data.platform}
                url={post.data.url}
                date={post.data.date}
                excerpt={post.data.excerpt}
                image={post.data.image}
                likes={post.data.likes}
                comments={post.data.comments}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ USER GROUP ============ -->
  <section class="slab">
    <div class="container">
      <div class="ug-layout">
        <div class="ug-body">
          <span class="eyebrow"><span class="section-no">05</span> Community</span>
          <h2 class="ug-heading">
            Join the <span class="italic">Finance Fabric</span> User Group.
          </h2>
          <p class="ug-desc">
            A free monthly user group for finance professionals exploring
            Microsoft Fabric Planning. Hosted by Khaled Chowdhury and Alex
            McPherson. Each session covers one real-world topic — modeling
            patterns, migration stories, writeback, security — followed by open
            Q&amp;A.
          </p>
          <div class="ug-actions">
            <a
              class="btn btn-primary"
              href="https://www.meetup.com/finance-fabric-user-group/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Join on Meetup <span class="arr">→</span>
            </a>
            <span class="pill">Free · monthly · virtual</span>
          </div>
        </div>

        <div class="ug-art">
          <div class="ug-art-headline">
            Where finance meets <span class="italic">fabric.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ NEWSLETTER ============ -->
  <section class="newsletter">
    <div class="container newsletter-inner">
      <div>
        <span class="eyebrow"><span class="section-no">06</span> Subscribe</span>
        <h2 class="newsletter-heading">
          Stay in the <span class="italic">loop</span> →
        </h2>
        <p class="newsletter-lead">
          Get the latest on Microsoft Fabric Planning delivered to your inbox.
          No spam, just insights.
        </p>
      </div>
      <form
        class="newsletter-form"
        name="newsletter"
        method="POST"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <label for="nl-email"></label>
        <div class="newsletter-form-row">
          <input
            id="nl-email"
            type="email"
            name="email"
            placeholder="you@company.com"
            required
            class="newsletter-input"
          />
          <button type="submit">Subscribe</button>
        </div>
        <small class="newsletter-note">
          Published by Khaled Chowdhury · archived on Substack
        </small>
      </form>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(234, 246, 243, 0.035) 1px, transparent 1px);
    background-size: calc(100% / 12) 100%;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, #000 0%, transparent 80%);
  }
  .hero::after {
    content: "";
    position: absolute;
    top: -30%;
    right: -15%;
    width: 65%;
    height: 140%;
    background: radial-gradient(closest-side, var(--cyan-haze), transparent 70%);
    pointer-events: none;
    filter: blur(10px);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 128px 0 104px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 72px;
    align-items: end;
  }

  .hero-main h1 {
    font-weight: 500;
    font-size: clamp(52px, 7vw, 104px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin-top: 28px;
    max-width: 14ch;
    color: var(--fg);
  }
  .hero-main h1 .italic {
    font-size: 1.04em;
    line-height: 0.9;
  }

  .hero-sub {
    margin-top: 32px;
    max-width: 58ch;
    font-size: 18px;
    line-height: 1.6;
    color: var(--fg-soft);
  }
  .hero-actions {
    margin-top: 44px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px 20px;
  }

  /* Hero side card */
  .hero-side {
    position: relative;
    background:
      linear-gradient(180deg, rgba(0, 240, 209, 0.04) 0%, transparent 40%),
      var(--bg-1);
    padding: 28px 28px 24px;
    border: 1px solid var(--rule-strong);
    border-radius: 14px;
    min-width: 0;
    box-shadow:
      0 24px 60px -20px rgba(0, 0, 0, 0.8),
      inset 0 0 60px -20px var(--cyan-glow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero-side::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  }

  .hero-side-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 18px;
  }

  .live-badge {
    color: var(--cyan);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-weight: 500;
  }
  .live-badge::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    animation: pulse 2.2s ease-in-out infinite;
  }

  .hero-side-thumb {
    margin-bottom: 18px;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: var(--bg-2);
    border: 1px solid var(--rule);
  }
  .hero-side-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-side-thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(7, 10, 12, 0.5) 100%);
    pointer-events: none;
  }

  .hero-side-title {
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 22px;
  }

  .hero-side-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 20px;
    padding: 20px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 18px;
  }
  .meta-k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 6px;
  }
  .meta-v {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.3;
  }

  .hero-side-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    background: var(--cyan-weak);
    color: var(--cyan);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.18s;
    border: 1px solid rgba(0, 240, 209, 0.25);
  }
  .hero-side-cta:hover {
    background: var(--cyan);
    color: var(--cyan-ink);
    border-color: var(--cyan);
