---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.astro";
import BlogCard from "../components/BlogCard.astro";
import SocialCard from "../components/SocialCard.astro";
import { getEventStatus } from "../utils/eventStatus";
import { fetchSubstackPosts } from "../utils/substackFeed";
import blogStickyConfig from "../content/config/blog-sticky.json";

const allEvents = await getCollection("events");
const upcomingEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "upcoming")
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = allEvents
  .filter((e) => getEventStatus(e.data.date) === "past")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const socialPosts = (await getCollection("socialMedia")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Blog: Substack RSS
const allPosts = await fetchSubstackPosts();
const stickyUrl = blogStickyConfig.stickyPostUrl;
const stickyPost = stickyUrl
  ? allPosts.find((p) => p.url === stickyUrl)
  : undefined;
const nonStickyPosts = allPosts
  .filter((p) => p.url !== stickyUrl)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
  .slice(0, 4);
const blogPosts = [
  ...(stickyPost ? [stickyPost] : []),
  ...nonStickyPosts,
];
---

<Layout
  title="Fabric Planning — The Microsoft Fabric Knowledge Hub"
  description="Everything you need to understand, evaluate, and implement Microsoft Fabric Planning. Built by practitioners, for practitioners."
>
  {/* ============================================================ */}
  {/* Section 1: Hero */}
  {/* ============================================================ */}
  <section
    class="relative w-full text-white"
    style="background: linear-gradient(135deg, #0f2b1e 0%, #1a1035 50%, #0f2b1e 100%);"
  >
    <div
      class="mx-auto flex max-w-[1200px] flex-col items-center px-6 py-24 text-center md:py-32"
    >
      <p
        class="mb-6 text-xs font-semibold uppercase tracking-[0.2em] text-light-purple"
      >
        Microsoft Fabric Knowledge Hub
      </p>
      <h1
        class="mb-6 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl"
      >
        The knowledge hub for Microsoft Fabric Planning
      </h1>
      <p
        class="mb-10 max-w-2xl text-lg leading-relaxed text-[#94a3b8] md:text-xl"
      >
        Everything you need to understand, evaluate, and implement Microsoft
        Fabric Planning. Built by practitioners, for practitioners.
      </p>
      <a
        href="https://fabricplanning.substack.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-lg px-8 py-4 text-base font-semibold text-white shadow-md transition hover:shadow-lg"
        style="background: linear-gradient(135deg, #7B61B8 0%, #5B3F9E 100%);"
      >
        Subscribe for updates
      </a>
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 2: What is Fabric Planning? */}
  {/* ============================================================ */}
  <section class="bg-purple-wash">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div class="mx-auto max-w-[680px] text-center">
        <h2
          class="mb-4 text-3xl font-bold tracking-tight text-forest md:text-4xl"
        >
          What is Fabric Planning?
        </h2>
        <div
          class="mx-auto mb-10 h-1 w-24 rounded-full"
          style="background: linear-gradient(90deg, #7B61B8 0%, #3BA776 100%);"
          aria-hidden="true"
        >
        </div>
        <div class="space-y-6 text-left text-base leading-relaxed text-slate-text md:text-lg">
          <p>
            Microsoft Fabric Planning is a new capability within the Microsoft
            Fabric platform that brings budgeting, forecasting, and financial
            planning directly into the unified analytics environment. For the
            first time, finance teams can build planning models alongside
            their existing Power BI reports and Fabric data pipelines.
          </p>
          <p>
            This represents a potential shift away from standalone EPM tools
            and Excel-based planning toward an integrated, cloud-native
            approach. Fabric Planning is still evolving, and this knowledge
            hub exists to help finance and data professionals navigate what
            it can do today, where the gaps are, and how to get started.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 3: Events (two-column: Upcoming | Past) */}
  {/* ============================================================ */}
  <section class="bg-white">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div
        class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-forest md:text-4xl">
            Events
          </h2>
          <p class="mt-2 text-base text-gray-muted">
            Upcoming sessions, past recordings, and community meetups
          </p>
        </div>
        <a
          href="/resources/events"
          class="text-sm font-semibold text-deep-green hover:underline"
        >
          View all events &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2">
        {/* LEFT: Upcoming Events */}
        <div class="flex flex-col pr-0 md:pr-8">
          <h3 class="mb-4 text-xl font-bold text-forest">
            <span class="mr-1 inline-block h-3 w-3 rounded-sm bg-medium-green" aria-hidden="true"></span>
            Upcoming Events
          </h3>
          {
            upcomingEvents.length === 0 ? (
              <p class="text-sm text-gray-muted">
                No upcoming events scheduled. Check back soon.
              </p>
            ) : (
              <div
                id="events-upcoming-scroll"
                class="-mx-2 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-2 pb-2"
                style="scrollbar-width: thin;"
              >
                {upcomingEvents.map((event) => (
                  <div class="shrink-0 snap-start">
                    <EventCard
                      title={event.data.title}
                      date={event.data.date}
                      time={event.data.time}
                      location={event.data.location}
                      type={event.data.type}
                      registrationUrl={event.data.registrationUrl}
                      featuredImage={event.data.featuredImage}
                    />
                  </div>
                ))}
              </div>
            )
          }
        </div>

        {/* Mobile divider */}
        <div class="my-8 border-t md:hidden" style="border-color: #cbd5e1;"></div>

        {/* Desktop divider + RIGHT: Past Events */}
        <div class="flex flex-col pl-0 md:border-l md:pl-8" style="--tw-border-opacity:1; border-color: #cbd5e1;">
          <h3 class="mb-4 text-xl font-bold text-forest">
            <span class="mr-1 inline-block h-3 w-3 rounded-sm bg-gray-muted" aria-hidden="true"></span>
            Past Events
          </h3>
          {
            pastEvents.length === 0 ? (
              <p class="text-sm text-gray-muted">No past events yet.</p>
            ) : (
              <div
                id="events-past-scroll"
                class="-mx-2 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-2 pb-2"
                style="scrollbar-width: thin;"
              >
                {pastEvents.map((event) => (
                  <div class="shrink-0 snap-start">
                    <EventCard
                      title={event.data.title}
                      date={event.data.date}
                      time={event.data.time}
                      location={event.data.location}
                      type={event.data.type}
                      registrationUrl={event.data.registrationUrl}
                      featuredImage={event.data.featuredImage}
                    />
                  </div>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 4: From the Blog (two-column) */}
  {/* ============================================================ */}
  <section class="bg-[#f8fafc]">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div
        class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <h2 class="text-3xl font-bold tracking-tight text-forest md:text-4xl">
          From the Blog
        </h2>
        <a
          href="/resources/blog"
          class="text-sm font-semibold text-deep-green hover:underline"
        >
          View all &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2">
        {/* LEFT: Fabric Planning on Substack */}
        <div class="flex flex-col pr-0 md:pr-8">
          <h3 class="mb-1 text-xl font-bold text-forest">
            <span style="color: #FF6719;">&#9632;</span> Fabric Planning on Substack
          </h3>
          <p class="mb-6 text-sm text-gray-muted">
            Articles and insights from our publication
          </p>

          {
            blogPosts.length === 0 ? (
              <p class="mb-6 text-sm text-gray-muted">
                Coming soon. Subscribe to be notified when we publish our first article.
              </p>
            ) : (
              <div
                id="blog-scroll"
                class="-mx-2 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-2 pb-2"
                style="scrollbar-width: thin;"
              >
                {blogPosts.map((post) => (
                  <div class="shrink-0 snap-start">
                    <BlogCard
                      title={post.title}
                      description={post.description}
                      pubDate={post.pubDate}
                      url={post.url}
                      coverImage={post.coverImage}
                    />
                  </div>
                ))}
              </div>
            )
          }

          <div class="mt-auto pt-6">
            <a
              href="https://fabricplanning.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg px-6 py-3 text-sm font-semibold text-white shadow-md transition hover:shadow-lg"
              style="background-color: #FF6719;"
            >
              Subscribe on Substack
            </a>
          </div>
        </div>

        {/* Mobile divider */}
        <div class="my-8 border-t md:hidden" style="border-color: #cbd5e1;"></div>

        {/* Desktop divider + RIGHT: Other Community Blogs */}
        <div class="flex flex-col pl-0 md:border-l md:pl-8" style="--tw-border-opacity:1; border-color: #cbd5e1;">
          <h3 class="mb-1 text-xl font-bold text-forest">
            Other Community Blogs
          </h3>
          <p class="mb-6 text-sm text-gray-muted">
            Curated posts from across the Fabric Planning community
          </p>

          <div class="flex flex-1 flex-col items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white px-6 py-12 text-center">
            <p class="mb-2 text-base font-semibold text-forest">Coming soon</p>
            <p class="max-w-sm text-sm text-gray-muted">
              We're building a curated collection of the best Fabric Planning
              content from across the community. Check back soon.
            </p>
          </div>

          <div class="mt-6">
            <span
              class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-slate-50 px-6 py-3 text-sm font-semibold text-gray-muted"
            >
              Coming soon
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 5: From the community (horizontal scroll) */}
  {/* ============================================================ */}
  <section class="bg-white">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div
        class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-forest md:text-4xl">
            From the community
          </h2>
          <p class="mt-2 text-base text-gray-muted">
            Discussions, insights, and updates from across social media
          </p>
        </div>
        <a
          href="/resources/social-media"
          class="text-sm font-semibold text-deep-green hover:underline"
        >
          View all &rarr;
        </a>
      </div>

      {
        socialPosts.length === 0 ? (
          <p class="text-base text-gray-muted">
            No community posts yet. Check back soon.
          </p>
        ) : (
          <div
            id="social-scroll"
            class="-mx-6 flex snap-x snap-mandatory justify-start gap-6 overflow-x-auto scroll-smooth px-6 pb-2"
            style="scrollbar-width: thin;"
          >
            {socialPosts.map((post) => (
              <div class="shrink-0 snap-start">
                <SocialCard
                  author={post.data.author}
                  platform={post.data.platform}
                  url={post.data.url}
                  date={post.data.date}
                  excerpt={post.data.excerpt}
                  image={post.data.image}
                />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 6: Finance Fabric User Group */}
  {/* ============================================================ */}
  <section class="bg-forest text-white">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <p
            class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-mint-teal"
          >
            Community
          </p>
          <h2
            class="mb-6 text-3xl font-bold tracking-tight text-white md:text-4xl"
          >
            Join the Finance Fabric User Group
          </h2>
          <p class="mb-8 max-w-xl text-base leading-relaxed text-white/80">
            A free monthly user group for finance professionals exploring
            Microsoft Fabric Planning. Hosted by Khaled Chowdhury and Alex
            McPherson, each session covers a real-world topic — from modeling
            patterns to migration stories — followed by open Q&amp;A with the
            community.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="https://www.meetup.com/finance-fabric-user-group/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-semibold text-white shadow-md transition hover:shadow-lg"
              style="background: linear-gradient(135deg, #3BA776 0%, #1B7A50 100%);"
            >
              Join on Meetup
            </a>
            <span class="text-sm text-white/70">Free to join</span>
          </div>
        </div>

        <div class="flex justify-center md:justify-end">
          <img
            src="https://media.fabricplanning.io/branding/Finance%20Fabric%20User%20Group.png"
            alt="Finance Fabric User Group - Where Finance Meets Fabric"
            loading="lazy"
            class="w-full max-w-[440px] rounded-xl object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ */}
  {/* Section 7: Newsletter CTA */}
  {/* ============================================================ */}
  <section style="background-color: #7B61B8;">
    <div class="mx-auto max-w-[1200px] px-6 py-20 md:py-24">
      <div class="mx-auto flex max-w-2xl flex-col items-center text-center">
        <h2
          class="mb-4 text-3xl font-bold tracking-tight text-white md:text-4xl"
        >
          Stay in the loop
        </h2>
        <p class="mb-8 text-base text-white/85 md:text-lg">
          Get the latest on Microsoft Fabric Planning delivered to your inbox.
          No spam, just insights.
        </p>
        <a
          href="https://fabricplanning.substack.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-fabric-purple shadow-md transition hover:shadow-lg"
        >
          Subscribe on Substack
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Horizontal scroll arrow buttons (Events section)
  document.querySelectorAll<HTMLButtonElement>("button[data-scroll]").forEach(
    (btn) => {
      btn.addEventListener("click", () => {
        const targetId = btn.dataset.scroll;
        const direction = Number(btn.dataset.direction ?? "1");
        if (!targetId) return;
        const container = document.getElementById(`${targetId}-scroll`);
        if (!container) return;
        const amount = Math.min(container.clientWidth * 0.8, 600);
        container.scrollBy({ left: amount * direction, behavior: "smooth" });
      });
    },
  );
</script>
